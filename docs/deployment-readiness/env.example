# Safe local defaults only. This file contains no secrets and does not enable hosting.
ATG_HOST=127.0.0.1
ATG_PORT=8787
ATG_REQUIRE_API_KEY=false
ATG_CLIENTS_FILE=./gateway-clients.json
ATG_LOG_FILE=./gateway-logs/gateway-requests.jsonl
ATG_PUBLIC_BASE_URL=
ATG_HOSTED_DEPLOYMENT_ENABLED=false
ATG_PAYMENT_ENABLED=false
ATG_AUTOMATIC_PURCHASE_ENABLED=false
ATG_BILLING_ENABLED=false

# Future production requirements; placeholders are intentionally empty.
ATG_TLS_TERMINATION=
ATG_MANAGED_SECRETS_PROVIDER=
ATG_PRODUCTION_IDENTITY_PROVIDER=
ATG_RATE_LIMIT_POLICY=
ATG_MONITORING_ENDPOINT=
ATG_ENVIRONMENT=local
