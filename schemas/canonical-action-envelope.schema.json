{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Gareth1953/agent-trust-gate/schemas/canonical-action-envelope.schema.json",
  "title": "Agent Trust Gate Canonical Action Envelope",
  "description": "Versioned local-reference envelope whose SHA-256 digest binds one exact consequential action. Hashing is not digital signing.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "actionEnvelopeVersion", "canonicalizationVersion", "digestAlgorithm", "issuerIdentity", "issuerKeyId",
    "verificationProfile", "subjectAgentIdentity", "nativeSessionId", "nativeRunId", "operatorIdentity",
    "mandateIdentity", "mandateReference", "mandateDigest", "policyReference", "policyDigest",
    "evidenceReference", "evidenceDigest", "approvalRequired", "humanApprovalReference", "humanApprovalDigest",
    "toolIdentity", "toolSchemaVersion", "operationName", "canonicalArguments", "targetIdentity", "amount",
    "currency", "operatingEnvironment", "issuedAt", "notBefore", "expiresAt", "nonce", "idempotencyKey",
    "usageSemantics", "actionDigest"
  ],
  "properties": {
    "actionEnvelopeVersion": { "const": "atg.canonical-action-envelope.v1" },
    "canonicalizationVersion": { "const": "atg.canonical-json.v1" },
    "digestAlgorithm": { "const": "sha256" },
    "issuerIdentity": { "$ref": "#/definitions/nonEmptyString" },
    "issuerKeyId": { "$ref": "#/definitions/nonEmptyString" },
    "verificationProfile": { "$ref": "#/definitions/nonEmptyString" },
    "subjectAgentIdentity": { "$ref": "#/definitions/nonEmptyString" },
    "nativeSessionId": { "$ref": "#/definitions/nonEmptyString" },
    "nativeRunId": { "$ref": "#/definitions/nonEmptyString" },
    "operatorIdentity": { "type": ["string", "null"], "minLength": 1 },
    "mandateIdentity": { "type": ["string", "null"], "minLength": 1 },
    "mandateReference": { "$ref": "#/definitions/nonEmptyString" },
    "mandateDigest": { "$ref": "#/definitions/sha256" },
    "policyReference": { "$ref": "#/definitions/nonEmptyString" },
    "policyDigest": { "$ref": "#/definitions/sha256" },
    "evidenceReference": { "$ref": "#/definitions/nonEmptyString" },
    "evidenceDigest": { "$ref": "#/definitions/sha256" },
    "approvalRequired": { "type": "boolean" },
    "humanApprovalReference": { "type": ["string", "null"], "minLength": 1 },
    "humanApprovalDigest": { "oneOf": [{ "$ref": "#/definitions/sha256" }, { "type": "null" }] },
    "toolIdentity": { "$ref": "#/definitions/nonEmptyString" },
    "toolSchemaVersion": { "$ref": "#/definitions/nonEmptyString" },
    "operationName": { "$ref": "#/definitions/nonEmptyString" },
    "canonicalArguments": {},
    "targetIdentity": { "$ref": "#/definitions/nonEmptyString" },
    "amount": { "type": ["number", "null"], "minimum": 0 },
    "currency": { "type": ["string", "null"], "pattern": "^[A-Z]{3}$" },
    "operatingEnvironment": { "$ref": "#/definitions/nonEmptyString" },
    "issuedAt": { "type": "string", "format": "date-time" },
    "notBefore": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "nonce": { "$ref": "#/definitions/nonEmptyString" },
    "idempotencyKey": { "$ref": "#/definitions/nonEmptyString" },
    "usageSemantics": { "const": "one_shot" },
    "actionDigest": { "$ref": "#/definitions/sha256" }
  },
  "definitions": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
