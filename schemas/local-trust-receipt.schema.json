{
  "title": "Agent Trust Gate Local Trust Receipt",
  "description": "Documentation schema for the local v2 gate-pass, review, and refusal receipt shape. It is not a production response contract or cryptographic proof.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "request_id",
    "action_id",
    "agent_id",
    "requested_action",
    "action_category",
    "mandate_id",
    "evidence_id",
    "verdict",
    "allowed",
    "settlement_allowed",
    "settlement_executed",
    "receipt_type",
    "risk_tier",
    "policy_decision",
    "policy_pack_version",
    "applied_policy",
    "risk_reason",
    "fast_path_allowed",
    "human_review_required",
    "issuer_ref",
    "verifier_ref",
    "proof_metadata",
    "checks",
    "reason_codes",
    "checked_at",
    "gate_pass_validity",
    "replay_protection",
    "signature_metadata",
    "audit_metadata"
  ],
  "properties": {
    "schema_version": { "const": "atg.local-gate-pass-receipt.v2" },
    "receipt_id": {
      "type": "string",
      "pattern": "^receipt_demo_[a-f0-9]{24}$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"
    },
    "action_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"
    },
    "agent_id": {
      "type": "string",
      "minLength": 1,
      "description": "Placeholder local demo identity."
    },
    "requested_action": {
      "type": "string",
      "minLength": 1,
      "description": "Reviewed description only; the receipt does not execute it."
    },
    "action_category": { "type": "string", "minLength": 1 },
    "mandate_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"
    },
    "evidence_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "allow_signed_gate_pass",
        "review_required",
        "refuse_no_mandate",
        "refuse_no_evidence",
        "refuse_stale_evidence",
        "refuse_no_verified_intent",
        "refuse_over_limit",
        "refuse_missing_approval",
        "refuse_unsafe_action"
      ]
    },
    "allowed": { "type": "boolean" },
    "settlement_allowed": {
      "type": "boolean",
      "description": "Local artifact eligibility only; never settlement execution or payment authorization."
    },
    "settlement_executed": { "const": false },
    "receipt_type": {
      "type": "string",
      "enum": ["signed_gate_pass", "review_receipt", "refusal_receipt"]
    },
    "risk_tier": {
      "type": "string",
      "enum": ["low", "medium", "high", "blocked"]
    },
    "policy_decision": {
      "type": "string",
      "enum": ["allow", "review_required", "refuse"]
    },
    "policy_pack_version": { "const": "local-demo-v1" },
    "issuer_ref": {
      "type": "string",
      "pattern": "^local_[A-Za-z0-9_.:-]{3,80}$"
    },
    "verifier_ref": {
      "type": "string",
      "pattern": "^local_[A-Za-z0-9_.:-]{3,80}$"
    },
    "proof_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "proof_purpose",
        "proof_status",
        "issuer_ref",
        "verifier_ref",
        "created_at",
        "expires_at",
        "nonce",
        "local_only",
        "replay_freshness"
      ],
      "properties": {
        "schema_version": { "const": "atg.local-proof-metadata.v1" },
        "proof_purpose": { "const": "pre_action_trust_gate" },
        "proof_status": {
          "type": "string",
          "enum": ["verified", "review_required", "blocked"]
        },
        "issuer_ref": {
          "type": "string",
          "pattern": "^local_[A-Za-z0-9_.:-]{3,80}$"
        },
        "verifier_ref": {
          "type": "string",
          "pattern": "^local_[A-Za-z0-9_.:-]{3,80}$"
        },
        "created_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "nonce": {
          "type": "string",
          "pattern": "^nonce_[A-Za-z0-9_-]{8,80}$"
        },
        "local_only": { "const": true },
        "replay_freshness": {
          "type": "object",
          "additionalProperties": false,
          "required": ["nonce", "single_use", "freshness_window_seconds", "replay_protection"],
          "properties": {
            "nonce": {
              "type": "string",
              "pattern": "^nonce_[A-Za-z0-9_-]{8,80}$"
            },
            "single_use": { "const": true },
            "freshness_window_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
            "replay_protection": {
              "type": "string",
              "enum": ["local_in_memory_single_use", "not_applicable"]
            }
          }
        }
      }
    },
    "applied_policy": { "type": "string", "minLength": 1 },
    "risk_reason": { "type": "string", "minLength": 1 },
    "fast_path_allowed": { "type": "boolean" },
    "human_review_required": { "type": "boolean" },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mandate", "evidence", "verified_intent", "limits", "approval"],
      "properties": {
        "mandate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "reason"],
          "properties": {
            "passed": { "type": "boolean" },
            "reason": { "type": "string", "minLength": 1 }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "fresh", "reason"],
          "properties": {
            "passed": { "type": "boolean" },
            "fresh": { "type": "boolean" },
            "reason": { "type": "string", "minLength": 1 }
          }
        },
        "verified_intent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "reason"],
          "properties": {
            "passed": { "type": "boolean" },
            "reason": { "type": "string", "minLength": 1 }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "reason"],
          "properties": {
            "passed": { "type": "boolean" },
            "reason": { "type": "string", "minLength": 1 }
          }
        },
        "approval": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "required", "reason"],
          "properties": {
            "passed": { "type": "boolean" },
            "required": { "type": "boolean" },
            "reason": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "reason_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "checked_at": { "type": "string", "format": "date-time" },
    "gate_pass_validity": {
      "description": "Allow-only bounded local validity metadata; null for review and refusal.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "issued_at",
            "valid_from",
            "expires_at",
            "ttl_seconds",
            "maximum_ttl_seconds"
          ],
          "properties": {
            "issued_at": { "type": "string", "format": "date-time" },
            "valid_from": { "type": "string", "format": "date-time" },
            "expires_at": { "type": "string", "format": "date-time" },
            "ttl_seconds": { "type": "integer", "minimum": 1, "maximum": 300 },
            "maximum_ttl_seconds": { "const": 300 }
          }
        }
      ]
    },
    "replay_protection": {
      "description": "Process-local simulation metadata only; not durable production replay protection.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["replay_key", "single_use", "protection_mode"],
          "properties": {
            "replay_key": {
              "type": "string",
              "pattern": "^replay_demo_[a-f0-9]{32}$"
            },
            "single_use": { "const": true },
            "protection_mode": { "const": "local_in_memory_single_use" }
          }
        }
      ]
    },
    "signature_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signature_mode", "algorithm", "note"],
      "properties": {
        "signature_mode": { "const": "local_demo_placeholder" },
        "algorithm": { "const": "none" },
        "note": {
          "type": "string",
          "description": "Must identify the signature as a non-cryptographic local placeholder."
        }
      }
    },
    "audit_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "source",
        "local_only",
        "private_data_included",
        "network_call_performed",
        "external_agent_contacted",
        "payment_triggered",
        "action_executed"
      ],
      "properties": {
        "schema_version": { "const": "atg.local-gate-pass-receipt.v2" },
        "source": { "const": "local_gate_pass_demo" },
        "local_only": { "const": true },
        "private_data_included": { "const": false },
        "network_call_performed": { "const": false },
        "external_agent_contacted": { "const": false },
        "payment_triggered": { "const": false },
        "action_executed": { "const": false }
      }
    }
  }
}
