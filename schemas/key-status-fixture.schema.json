{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Gareth1953/agent-trust-gate/schemas/key-status-fixture.schema.json",
  "title": "Agent Trust Gate Local Verification-Key Status Fixture",
  "description": "Non-production public-key fixture status model. It provides no production key custody or revocation service.",
  "type": "object",
  "additionalProperties": false,
  "required": ["fixtureVersion", "profileId", "keys", "localOnly", "productionKeyCustody"],
  "properties": {
    "fixtureVersion": { "const": "atg.key-status-fixture.local.v1" },
    "profileId": { "type": "string", "minLength": 1 },
    "keys": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["issuerIdentity", "keyId", "algorithm", "status", "publicKeyPem", "acceptedForVerification", "acceptedForIssuance", "note"],
        "properties": {
          "issuerIdentity": { "type": "string", "minLength": 1 },
          "keyId": { "type": "string", "minLength": 1 },
          "algorithm": { "const": "ed25519-local-demo" },
          "status": { "enum": ["active", "rotated", "revoked", "unknown"] },
          "publicKeyPem": { "type": ["string", "null"] },
          "acceptedForVerification": { "type": "boolean" },
          "acceptedForIssuance": { "type": "boolean" },
          "note": { "type": "string", "minLength": 1 }
        }
      }
    },
    "localOnly": { "const": true },
    "productionKeyCustody": { "const": false }
  }
}
