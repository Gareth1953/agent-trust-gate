{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Gareth1953/agent-trust-gate/schemas/nonce-state.schema.json",
  "title": "Agent Trust Gate Local Nonce State",
  "description": "Explicit same-process local nonce state. Cross-process atomicity is not provided.",
  "type": "object",
  "additionalProperties": false,
  "required": ["stateVersion", "nonce", "gatePassId", "actionDigest", "expiresAt", "status", "updatedAt", "transitions", "localProcessOnly", "crossProcessAtomicity"],
  "properties": {
    "stateVersion": { "const": "atg.nonce-state.local.v1" },
    "nonce": { "type": "string", "minLength": 1 },
    "gatePassId": { "type": "string", "minLength": 1 },
    "actionDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "status": { "enum": ["unused", "reserved", "consumed", "expired", "failed", "abandoned"] },
    "updatedAt": { "type": "string", "format": "date-time" },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "at", "reasonCode"],
        "properties": {
          "from": { "type": ["string", "null"], "enum": [null, "unused", "reserved", "consumed", "expired", "failed", "abandoned"] },
          "to": { "enum": ["unused", "reserved", "consumed", "expired", "failed", "abandoned"] },
          "at": { "type": "string", "format": "date-time" },
          "reasonCode": { "type": "string", "minLength": 1 }
        }
      }
    },
    "localProcessOnly": { "const": true },
    "crossProcessAtomicity": { "const": false }
  }
}
